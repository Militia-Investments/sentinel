# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Benzinga
BENZINGA_API_KEY=...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
SENTINEL_ADMIN_CHANNEL=C0123456789

# AWS
AWS_REGION=us-east-1
DYNAMODB_TABLE_IDEAS=sentinel_ideas
DYNAMODB_TABLE_ARTICLES=sentinel_articles
DYNAMODB_TABLE_ALERTS=sentinel_alerts

# Polling
POLL_INTERVAL_SECONDS=300

# Relevance thresholds (score out of 10, lower = more sensitive)
RELEVANCE_THRESHOLD_LOW=8
RELEVANCE_THRESHOLD_MEDIUM=6
RELEVANCE_THRESHOLD_HIGH=4

# Kelly sizing
FRACTIONAL_KELLY_MULTIPLIER=0.25
